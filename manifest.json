{
  "manifest_version": 3,
  "name": "Managed Files",
  "version": "1.3",
  "description": "Blocks specified local file types from opening in Chrome (managed by policy).",
  "permissions": [
    "webNavigation",
    "tabs",
    "storage"
  ],
  "host_permissions": ["file:///*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "storage": {
    "managed_schema": "schema.json"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["file:///*"]
    }
  ]
}
